# ─────────────────────────────────────────────────────────────
#  NEXUS-MD — Environment Variables for Panel / VPS Deployment
#  Copy this file to .env and fill in your values.
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Your WhatsApp session ID — get one free at https://nexs-session-1.replit.app
SESSION_ID=NEXUS-MD:~paste_your_session_here

# Your WhatsApp number (no + sign). Multiple owners: 254706535581,254781346242
ADMIN_NUMBERS=254706535581

# HTTP port for the web dashboard (default: 5000)
PORT=5000

# Your bot display name (shown in menus and messages)
BOTNAME=NEXUS-MD

# PostgreSQL connection string (optional — leave blank to use local file storage)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Set to "true" to force-print QR code in terminal (useful if pairing site is down)
# PRINT_QR=true

# AI keys (optional — only needed if you use AI commands)
# GROQ_API_KEY=your_groq_key_here
# OPENAI_API_KEY=your_openai_key_here
